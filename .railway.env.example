# Empire Video Production System - Railway Environment Variables
# Copy these to your Railway project Variables tab and fill in the values

# ===== EXISTING VARIABLES (keep these) =====
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_TRADE=false

ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here
GROK_API_KEY=your_xai_key_here

TRADOVATE_USER=APEX_589296
TRADOVATE_PASS=your_tradovate_password_here
TRADOVATE_MODE=demo

SYNTHESIA_API_KEY=your_synthesia_key_here
SYNTHESIA_WEBHOOK_SECRET=your_synthesia_webhook_secret_here

YOUTUBE_API_KEY=your_youtube_key_here
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_refresh_token_here

STOP_TRADING=false
EMPIRE_ACCOUNT_SIZE=100000
EMPIRE_HARD_STOP=80000
EMPIRE_REDUCE_AT=90000
PROP_PROFIT_TARGET=1500
PROP_DAILY_LOSS_LIMIT=1000
HEALTH_CHECK_INTERVAL=60
PORT=10000

# ===== NEW: VIDEO PRODUCTION SYSTEM VARIABLES =====

# Video Generator Configuration
VIDEO_GENERATOR_PORT=5003
VIDEO_GENERATOR_ENABLED=true

# Video Editor Configuration
VIDEO_EDITOR_PORT=5001
VIDEO_EDITOR_API_URL=http://localhost:5001

# Auto-Editor Configuration
VIDEO_AUTO_EDITOR_PORT=5002
VIDEO_AUTO_EDITOR_URL=http://localhost:5002

# Maximum video file size (500MB)
MAX_VIDEO_SIZE=500000000

# Storage paths (Railway uses ephemeral storage)
TEMP_STORAGE=/tmp/video-editor
EXPORT_STORAGE=/tmp/video-exports

# FFmpeg path (pre-installed in Docker)
FFMPEG_PATH=ffmpeg

# edge-tts (AI voice) configuration
EDGE_TTS_ENABLED=true

# YouTube auto-publish settings
YOUTUBE_AUTO_PUBLISH=true
YOUTUBE_DEFAULT_PRIVACY=unlisted

# Video quality defaults
VIDEO_DEFAULT_QUALITY=1080p
VIDEO_EXPORT_FORMAT=mp4

# Performance tuning
VIDEO_PROCESSING_TIMEOUT=300
VIDEO_ENCODING_THREADS=4
VIDEO_CLEANUP_INTERVAL=3600
