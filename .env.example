# Empire v2 - Production Environment Configuration
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets

# ===== CORE API =====
PORT=8000
ENV=production
SECRET_KEY=your_secret_key_here_change_in_production

# ===== DATABASE =====
DATABASE_URL=sqlite:///./empire.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/empire_v2

# ===== STRIPE (Payment Processing) =====
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===== VIDEO PRODUCTION =====
HEYGAN_API_KEY=your_heygan_api_key
HEYGAN_API_BASE_URL=https://api.heygen.com

# ===== DELIVERY APP =====
# Real-time GPS tracking
DELIVERY_GPS_UPDATE_INTERVAL=5
DELIVERY_TRACKING_TIMEOUT=300

# Restaurant seeding (initial data)
SEED_RESTAURANTS=true
RESTAURANT_COUNT=5

# Driver assignment radius (km)
DRIVER_ASSIGNMENT_RADIUS=5

# ===== EMAIL NOTIFICATIONS =====
GMAIL_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=your_app_password_here
# Note: Use Gmail App Passwords, not your regular Gmail password

# ===== TRADING/CRYPTO (Optional) =====
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_TRADE=false

ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_openai_key_here
GROK_API_KEY=your_xai_key_here

# ===== YOUTUBE AUTOMATION (Optional) =====
YOUTUBE_API_KEY=your_youtube_key
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token
YOUTUBE_AUTO_PUBLISH=false

# ===== SYNTHESIA (Optional) =====
SYNTHESIA_API_KEY=your_synthesia_key
SYNTHESIA_WEBHOOK_SECRET=your_webhook_secret

# ===== LOGGING =====
LOG_LEVEL=INFO
